# Copy this to `/opt/devflowfix/devflowfix.env` on the VPS and fill in real values.
# Use Docker DNS names or network aliases, not container IPs.

BACKEND_IMAGE=ghcr.io/owner/devflowfix:latest

ENVIRONMENT=prod
APP_BIND_IP=127.0.0.1
APP_HOST_PORT=8000
FORWARDED_ALLOW_IPS=*

DEVFLOWFIX_NETWORK=devflowfix
OPENMAILER_NETWORK=openmailer-runtime
SAFELINE_NETWORK=safeline-ce

DATABASE_URL=postgresql://postgres:change-me@devflowfix-pgvector:5432/vector_db
REDIS_URL=redis://your-redis-container-or-alias:6379/0

SECRET_KEY=change-me
JWT_SECRET_KEY=change-me

OPENAI_API_KEY=
NVIDIA_API_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_TOKEN=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=
GITHUB_APP_INSTALLATION_ID=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=
ZITADEL_ISSUER=
ZITADEL_CLIENT_ID=
ZITADEL_PROJECT_ID=
ZITADEL_API_URL=
BACKBLAZE_KEY_ID=
BACKBLAZE_APPLICATION_KEY=
BACKBLAZE_BUCKET_NAME=
BACKBLAZE_ENDPOINT_URL=
BACKBLAZE_REGION=us-west-001
