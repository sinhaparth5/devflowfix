# Copy to infrastructure/docker/dev.env for local Docker development.
# This file is intentionally separate from the repo root .env so Docker dev
# keeps using the local Postgres/Redis containers instead of any remote DB URL.

NGROK_AUTHTOKEN=
NGROK_DOMAIN=

NVIDIA_API_KEY=
NVIDIA_API_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_LLM_MODEL=qwen/qwen3-coder-480b-a35b-instruct
NVIDIA_EMBEDDING_MODEL=nvidia/nv-embedcode-7b-v1
NVIDIA_API_TIMEOUT=30
NVIDIA_MAX_RETRIES=3

GITHUB_TOKEN=
GITHUB_API_BASE_URL=https://api.github.com
